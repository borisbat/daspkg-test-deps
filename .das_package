options gen2

require daslib/daspkg

[export]
def package() {
    package_name("daspkg-test-deps")
    package_author("borisbat")
    package_description("Test package: module with dependencies")
    package_tag("test")
}

[export]
def dependencies(version : string) {
    require_package("github.com/borisbat/daspkg-test-pure")
}
